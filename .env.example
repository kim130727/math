# =========================================
# OpenAI API 설정 (필수)
# =========================================

OPENAI_API_KEY=your_openai_api_key_here


# =========================================
# TTS 옵션 (선택)
# =========================================

TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy


# =========================================
# Manim 설정 (선택)
# =========================================

# -pql (low), -pqm (medium), -pqh (high)
MANIM_QUALITY=-pqh


# =========================================
# 기타 옵션 (선택)
# =========================================

# 디버그 로그 출력
DEBUG=true